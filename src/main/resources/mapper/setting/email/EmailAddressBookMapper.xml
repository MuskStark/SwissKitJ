<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="fan.summer.database.mapper.setting.email.EmailAddressBookMapper">

    <insert id="insert"
            parameterType="fan.summer.database.entity.setting.email.EmailAddressBookEntity"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO email_address_book (email_address, nickname, tags)
        VALUES (#{emailAddress}, #{nickname}, #{tags, typeHandler=org.apache.ibatis.type.StringTypeHandler})
    </insert>

    <update id="update"
            parameterType="fan.summer.database.entity.setting.email.EmailAddressBookEntity">
        UPDATE email_address_book
        SET email_address = #{emailAddress}, nickname = #{nickname}, tags = #{tags}
        WHERE id = #{id}
    </update>

    <select id="selectEmailAddressBook"
            resultType="fan.summer.database.entity.setting.email.EmailAddressBookEntity">
        select *
        from email_address_book
    </select>
</mapper>