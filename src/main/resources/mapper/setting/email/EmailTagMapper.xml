<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="fan.summer.database.mapper.setting.email.EmailTagMapper">

    <!-- Insert a new email tag -->
    <insert id="insert"
            parameterType="fan.summer.database.entity.setting.email.EmailTagEntity"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO email_tag (tag) VALUES (#{tag})
    </insert>

    <!-- Update an existing email tag -->
    <update id="update"
            parameterType="fan.summer.database.entity.setting.email.EmailTagEntity">
        UPDATE email_tag SET tag = #{tag} WHERE id = #{id}
    </update>

    <!-- Select all email tags -->
    <select id="selectAll"
            resultType="fan.summer.database.entity.setting.email.EmailTagEntity">
        SELECT id, tag FROM email_tag ORDER BY id
    </select>

</mapper>