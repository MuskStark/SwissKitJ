<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="fan.summer.database.mapper.excel.ComplexSplitConfigMapper">

    <insert id="insert"
            parameterType="fan.summer.database.entity.excel.ComplexSplitConfigEntity"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO complex_split_config
            (task_id, field_name, sheet_name, header_index, column_index)
        VALUES
            (#{taskId}, #{fieldName}, #{sheetName}, #{headerIndex}, #{columnIndex})
    </insert>


</mapper>