<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="fan.summer.database.mapper.email.EmailMassSentConfigMapper">

    <!-- Upsert (insert or update) mass sent config by task_id -->
    <insert id="upsert"
            parameterType="fan.summer.database.entity.email.EmailMassSentConfigEntity"
            useGeneratedKeys="true"
            keyProperty="id">
        MERGE INTO email_mass_sent_config (task_id, to_tag, cc_tag, is_sent_att, att_folder_path)
        KEY (task_id)
        VALUES (#{taskId}, #{toTag}, #{ccTag}, #{isSentAtt}, #{attFolderPath})
    </insert>

    <!-- Select mass sent config by task_id -->
    <select id="selectByTaskId"
            parameterType="string"
            resultType="fan.summer.database.entity.email.EmailMassSentConfigEntity">
        SELECT id,
               task_id AS taskId,
               to_tag AS toTag,
               cc_tag AS ccTag,
               is_sent_att AS isSentAtt,
               att_folder_path AS attFolderPath
        FROM email_mass_sent_config
        WHERE task_id = #{taskId}
    </select>

    <!-- Select all mass sent config records -->
    <select id="selectAll"
            resultType="fan.summer.database.entity.email.EmailMassSentConfigEntity">
        SELECT id,
               task_id AS taskId,
               to_tag AS toTag,
               cc_tag AS ccTag,
               is_sent_att AS isSentAtt,
               att_folder_path AS attFolderPath
        FROM email_mass_sent_config
        ORDER BY id DESC
    </select>

    <!-- Delete mass sent config by task_id -->
    <delete id="deleteByTaskId" parameterType="string">
        DELETE FROM email_mass_sent_config
        WHERE task_id = #{taskId}
    </delete>

    <!-- Delete all mass sent config records -->
    <delete id="deleteAll">
        DELETE FROM email_mass_sent_config
    </delete>

</mapper>
